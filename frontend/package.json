{
  "name": "app-ef-frontend",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "app_ef frontend — a semantic-search corpus UI built on acture (command dispatch) + zodal (schema-driven UI), over the ef.EfService HTTP backend.",
  "scripts": {
    "predev": "pnpm run deps:build",
    "dev": "vite",
    "prebuild": "pnpm run deps:build",
    "build": "tsc && vite build",
    "deps:build": "pnpm run deps:build:zodal && pnpm run deps:build:shadcn",
    "deps:build:zodal": "cd ../../../i/_zodals/zodal && pnpm build",
    "deps:build:shadcn": "cd ../../../i/_zodals/zodal-ui-shadcn && pnpm build",
    "preview": "vite preview",
    "typecheck": "tsc",
    "typecheck:e2e": "tsc -p e2e/tsconfig.json",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "gen:api": "openapi-typescript src/api/openapi.json -o src/api/openapi.d.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.24",
    "@zodal/core": "link:../../../i/_zodals/zodal/packages/core",
    "@zodal/store": "link:../../../i/_zodals/zodal/packages/store",
    "@zodal/ui": "link:../../../i/_zodals/zodal/packages/ui",
    "@zodal/ui-shadcn": "link:../../../i/_zodals/zodal-ui-shadcn",
    "acture": "^1.2.1",
    "acture-ai-vercel": "^1.0.0",
    "acture-hotkeys": "^1.0.0",
    "acture-palette-react": "^1.0.0",
    "ai": "^4.3.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "acture-e2e-playwright": "^1.1.0",
    "autoprefixer": "^10.4.20",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
