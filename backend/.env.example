# app_ef backend configuration
#
# The backend is pure transport over ef.EfService; it has almost no config.
#
# APP_EF_CORS_ORIGINS: comma-separated CORS origin allowlist. When unset, the
# frontend dev-server defaults are used (http://localhost:5173 for Vite,
# http://localhost:3000 for CRA). Set this to your deployed frontend origin(s)
# in production.
#
# APP_EF_CORS_ORIGINS=https://app-ef.example.com
